# Runtime database connection.
# For Supabase this should be the pooled transaction URL, typically port 6543.
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres"

# Direct database connection for Prisma migrations and schema operations.
# For Supabase this should be the direct connection URL, typically port 5432.
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres"

# Auth.js secret. Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-secret"

# Public base URL for metadata, canonical links, and deployments.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: ImgBB image upload support.
IMGBB_API_KEY=""

# Optional: Web Push support.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:security@controlplane.local"

# Optional: local demo credentials for seeding and smoke tests.
DEMO_ADMIN_USERNAME="demo"
DEMO_ADMIN_EMAIL="demo@controlplane.local"
DEMO_ADMIN_PASSWORD="controlplane-demo"
